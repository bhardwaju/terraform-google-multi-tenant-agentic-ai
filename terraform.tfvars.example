# terraform.tfvars.example

# --- 1. The "Handshake" IDs (Basic Setup) ---
billing_account  = "012345-567890-ABCDEF"
folder_id        = "123456789012"
hub_project_id   = "agent-factory-hub-v1"
tenant_id_suffix = "prod-v1"             # Ensures uniqueness for mkt/hr projects

# --- 2. Organization & Governance (Required for PAB Isolation) ---
org_id           = "112233445566"        # Required for Principal Access Boundaries
region           = "us-central1"
domain_name      = "agents.your-corp.com"

# --- 3. The "Double-Lock" Project Numbers (Required for VPC-SC & PAB) ---
# Tip: Find these in the Google Cloud Console "Dashboard" for each project
access_policy_id   = "778899001122"      # The Access Context Manager Policy ID
hub_project_number = "100000000001"
mkt_project_number = "200000000002"
hr_project_number  = "300000000003"

# --- 4. Networking & Security (The Hybrid Toggle) ---
# PUBLIC MODE: Leave the list below as []
# INTERNAL-ONLY MODE: Add your Corporate VPN or Office Egress IPs
trusted_corporate_ip_ranges = ["203.0.113.0/24", "198.51.100.5/32"]

# --- 5. Application Config ---
frontend_portal_image = "us-docker.pkg.dev/cloudrun/container/hello"
